{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "bootstrap-sha": "2b44d88",
  "include-component-in-tag": true,
  "separate-pull-requests": false,
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "timr-client",
      "components": ["timr-sdk", "timr-cli", "timr-mcp"]
    }
  ],
  "packages": {
    "packages/sdk": {
      "package-name": "timr-sdk",
      "component": "timr-sdk",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/cli": {
      "package-name": "timr-cli",
      "component": "timr-cli",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/mcp": {
      "package-name": "timr-mcp",
      "component": "timr-mcp",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
