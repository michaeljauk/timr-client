{
  "name": "timr-mcp",
  "version": "0.3.1",
  "description": "Model Context Protocol server for the timr time-tracking API",
  "keywords": [
    "timr",
    "time-tracking",
    "mcp",
    "model-context-protocol"
  ],
  "license": "MIT",
  "author": "Michael Jauk",
  "repository": {
    "type": "git",
    "url": "https://github.com/michaeljauk/timr-client.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/michaeljauk/timr-client/tree/main/packages/mcp",
  "bugs": "https://github.com/michaeljauk/timr-client/issues",
  "type": "module",
  "bin": {
    "timr-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "generate": "node scripts/copy-spec.mjs",
